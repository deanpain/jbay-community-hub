# Altron/DHA batch verification (sandbox)
ALTRON_API_URL=https://api.altron-sandbox.gov.za/v1
ALTRON_API_KEY=<sandbox-key>
ALTRON_BATCH_SIZE_LIMIT=100
ALTRON_RATE_LIMIT_PER_HOUR=1000

# Identus VDR (sandbox)
IDENTUS_API_URL=https://<region>.atalaprism.io/api
IDENTUS_ISSUER_DID=did:identus:<uuid>
IDENTUS_API_KEY=<sandbox-key>

# KMS / Key Management (envelope encryption)
KMS_KEY_ALIAS=alias/identity-worker-dek
KMS_KEY_VERSION=v1
KMS_REGION=af-south-1
KMS_ENDPOINT=http://localhost:4566