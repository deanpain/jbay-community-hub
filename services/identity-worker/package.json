{
  "name": "identity-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "dry-run": "node --enable-source-maps --import tsx src/dry-run.ts"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.5",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
